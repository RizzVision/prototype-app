# RizzVision Backend Configuration
# Copy to .env and fill in your values
# NEVER commit .env to git

# Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Image Processing
IMAGE_MAX_DIMENSION=4000
IMAGE_TARGET_SIZE=512
IMAGE_MIN_DIMENSION=100

# Quality Gate Thresholds
BRIGHTNESS_MIN=40
BRIGHTNESS_MAX=230
SHARPNESS_MIN=100

# Color Extraction
KMEANS_CLUSTERS=3

# Gemini Model
GEMINI_MODEL=gemini-2.5-flash-lite

# Segmentation Model (HuggingFace model ID)
SEGMENTATION_MODEL=mattmdjaga/segformer_b2_clothes

# Logging
LOG_LEVEL=INFO
