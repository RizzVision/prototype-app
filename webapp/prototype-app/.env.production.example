# Production environment
# Copy to .env.production (or set these in your hosting platform env dashboard).

VITE_ANTHROPIC_API_KEY=your-production-anthropic-api-key
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_OAUTH_REDIRECT_URL=https://your-domain.com/auth/callback

# RizzVision FastAPI backend URL (deployed server running rv-final-prototype/main.py)
VITE_RIZZVISION_API_URL=https://your-rizzvision-backend-url

# Optional for server-side tooling/migrations
DATABASE_URL=your-production-postgres-connection-string
