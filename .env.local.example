# Local development environment
# Copy to .env.local and fill with your local/dev values.

VITE_ANTHROPIC_API_KEY=your-local-anthropic-api-key
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_OAUTH_REDIRECT_URL=http://localhost:5173/auth/callback
VITE_YOLO_API_URL=http://127.0.0.1:8001

# Optional for local Prisma usage
DATABASE_URL=your-local-or-remote-postgres-connection-string

# Backend JWT verification for local FastAPI
SUPABASE_URL=your-supabase-project-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_AUTH_TIMEOUT_SECONDS=5
